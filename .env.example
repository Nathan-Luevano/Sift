# Core app
DATABASE_PATH=./sift.db
LOG_LEVEL=INFO
LOG_FILE=./logs/sift.log

FLASK_SECRET_KEY=change-me
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=False

# Correlation settings
MAX_CORRELATION_DISTANCE_KM=50
CORRELATION_TIME_WINDOW_HOURS=24
MAX_OSINT_RESULTS=1000

# Optional Ollama integration
OLLAMA_ENABLE=False
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma:4b
OLLAMA_TIMEOUT=120

# Optional web intelligence
WEB_SEARCH_ENABLE=False
WEB_SEARCH_ENGINE=duckduckgo
WEB_SEARCH_MAX_RESULTS=50
WEB_SEARCH_TIMEOUT=45
WEB_SCRAPE_TIMEOUT=20
WEB_SCRAPE_MAX_PAGES=15

GOOGLE_SEARCH_ENGINE_ID=
GOOGLE_SEARCH_API_KEY=
SERPAPI_KEY=

SEARCH_DEPTH=deep
SEARCH_STRATEGY=multi_engine
ENABLE_SOCIAL_SEARCH=True
ENABLE_NEWS_ARCHIVE_SEARCH=True
ENABLE_ACADEMIC_SEARCH=True
SEARCH_LANGUAGES=en
SEARCH_REGIONS=us
ENABLE_REVERSE_IMAGE_SEARCH=False

# Browser settings for scraping
BROWSER_HEADLESS=True
BROWSER_TIMEOUT=30
BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# LLM generation settings
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
LLM_CONTEXT_WINDOW=8192

# Optional APIs
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SiftApp/1.0

GOOGLE_MAPS_API_KEY=
NEWS_API_KEY=

